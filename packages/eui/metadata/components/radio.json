{
  "name": "EuiRadio",
  "description": "Single radio button. Use EuiRadioGroup for a related set.",
  "visualDescription": "",
  "category": "Forms",
  "import": "import { EuiRadio } from '@elastic/eui';",
  "props": {
    "aria-label": {
      "type": "string",
      "required": false,
      "description": "Defines a string value that labels the current element.\n@see aria-labelledby."
    },
    "label": {
      "type": "ReactNode",
      "required": false
    },
    "name": {
      "type": "string",
      "required": false
    },
    "value": {
      "type": "string",
      "required": false
    },
    "checked": {
      "type": "boolean",
      "required": false
    },
    "disabled": {
      "type": "boolean",
      "required": false
    },
    "onChange": {
      "type": "ChangeEventHandler<HTMLInputElement>",
      "required": true
    },
    "labelProps": {
      "type": "CommonProps & LabelHTMLAttributes<HTMLLabelElement>",
      "required": false,
      "description": "Object of props passed to the `label` element"
    }
  },
  "example": "<EuiRadio id=\"radio\" label=\"Radio label\" value=\"radio-1\" />"
}