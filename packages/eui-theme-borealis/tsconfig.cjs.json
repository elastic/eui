{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "lib/cjs",
    "target": "es6",
    "module": "CommonJS",
    "tsBuildInfoFile": "lib/cjs/.tsbuildinfo",
    "importHelpers": false,
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules"
  ],
}
