{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@elastic/eui-config-tsconfig",
  "compilerOptions": {
    "outDir": "lib/esm",
    "target": "ES2020",
    "noEmitHelpers": true,
    "skipLibCheck": true,
    "tsBuildInfoFile": "lib/esm/.tsbuildinfo"
  },
  "include": [
    "src",
  ],
  "exclude": [
    "node_modules"
  ],
}
